# ── Credentials (required) ────────────────────────────────────────────────────
IKABOT_EMAIL=your_email@example.com
IKABOT_PASSWORD=your_password

# ── Data collection intervals ─────────────────────────────────────────────────
# Accepts: Nd (days), Nh (hours), Nm (minutes), Ns (seconds), or plain integer (seconds)

# How often to run the full empire data cycle (resources, buildings, movements)
EMPIRE_UPDATE_INTERVAL=1h

# How often to refresh building upgrade costs
BUILDING_COSTS_UPDATE_INTERVAL=3d

# How often to run the world scan (inactive/vacation players near own cities)
WORLD_SCAN_UPDATE_INTERVAL=7d

# ── World scan ────────────────────────────────────────────────────────────────

# Maximum tile distance from own cities to include islands in the world scan
WORLD_SCAN_RADIUS=10

# ── Anti-detection: active hours ──────────────────────────────────────────────
# Format: H-H (24h clock, e.g. 8-23 = 08:00 to 23:00)
# Leave unset or empty to operate 24 hours a day

# Hours during which the building queue may START CONSTRUCTIONS and DISPATCH TRANSPORTS.
# Outside this window the queue still checks city status but takes no action.
QUEUE_ACTIVE_HOURS=8-23

# Hours during which the bot runs FULL EMPIRE SCANS at the normal EMPIRE_UPDATE_INTERVAL.
# Outside this window it scans at SCAN_NIGHT_INTERVAL instead, reducing nightly HTTP activity.
# This is the most important anti-detection setting — regular hourly requests at 3 AM are
# the clearest bot signal visible in server logs.
SCAN_ACTIVE_HOURS=8-23

# How often to scan outside SCAN_ACTIVE_HOURS (keeps data roughly fresh overnight).
# Set to a larger value (e.g. 6h) if you want minimal overnight activity.
SCAN_NIGHT_INTERVAL=4h

# ── Notifications ─────────────────────────────────────────────────────────────

# Wine level below which a Telegram "critical" alert is sent (in hours until depletion)
WINE_CRITICAL_NOTIFY_HOURS=2h

# Telegram bot token (from @BotFather). Leave empty to disable Telegram notifications.
TELEGRAM_BOT_TOKEN=

# Telegram chat ID to send notifications to (your personal chat or a group).
# Find it by messaging @userinfobot on Telegram.
TELEGRAM_CHAT_ID=

# ── Logging ───────────────────────────────────────────────────────────────────

# Language for backend log messages printed to docker compose logs
# Options: en (English), pt (Portuguese)
LOG_LANG=en
